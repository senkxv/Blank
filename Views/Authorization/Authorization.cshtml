@{
    Layout = null;
}
<!DOCTYPE html>
<html>
    <head>
        <title>Авторизация</title>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <link rel="stylesheet" href="~/css/site.css"/>
        <link rel="stylesheet" href="~/css/Authorization.css" />
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@300..700&family=SN+Pro:ital,wght@0,200..900;1,200..900&display=swap" rel="stylesheet"/>
    </head>
    <body>
        <header>
            <p class="header-welcome-text">Добро пожаловать!<p>
            <p>Еще не имеете аккаунта? <a id="registration-link" href="/">Зарегистрироваться</a></p>
        </header>
        <aside>
        </aside>
        <main>
            <section>
                <div class="form">
                    <form method="POST" class="main-section-form">
                        <label for="email">Электронная почта</label><br />
                        <input id="email" type="email" /><br />

                        <label for="FIO">ФИО</label><br />
                        <input id="FIO" type="text" /><br />

                        <label for="password">Пароль</label><br />
                        <input id="password" type="password" />
                        <ul class="form-list-password">
                            <li>Используйте 8 и более символов</li>
                            <li>Хотя бы один специальный символ</li>
                            <li>Хотя бы один символ в ВЕРХНЕМ регистре</li>
                            <li>Хотя бы одно число</li>
                        </ul>

                        <input id="checkbox-user-data-computing" type="checkbox" />
                        <label class="checkbox-user-data-computing" for=" checkbox-user-data-computing"> Я согласен на обработку персональных данных и с условиями использования сервиса.</label><br />

                        <input type="submit" value="Войти" />
                    </form>
                </div>
            </section>
        </main>
        <footer>

        </footer>
    </body>
</html>