<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Blank.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/_Layout.css" asp-append-version="true" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@300..700&family=SN+Pro:ital,wght@0,200..900;1,200..900&display=swap" rel="stylesheet" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Rubik:ital,wght@0,300..900;1,300..900&family=SN+Pro:ital,wght@0,200..900;1,200..900&display=swap" rel="stylesheet" />
</head>
<body>
    <header>
        <div class="header-container">
            <nav>
                <ul>
                    <li><a href="/">Главная</a></li>
                    <li><a href="/UserWorkspace/CreateDocumentPage">Добавить</a></li>
                    <li><a href="#" onclick="editSelectedDocument()">Изменить</a></li>
                    <li><a href="#" onclick="deleteSelectedDocument()">Удалить</a></li>
                    <li><a href="/UserWorkspace/ExportAllToExcel">Экспорт</a></li>
                    <li><a href="/UserWorkspace/Index">Обновить</a></li>
                    <li><a href="/Documents/Print">Печать</a></li>
                    <li><a href="#" id="searchLink">Поиск</a></li>
                    <li><a href="/Filtr">Фильтр</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <div class="content-wrapper">
        <main>
            <!-- Модальное окно поиска -->
            <div id="searchModal" style="display: none; position: fixed; top: 100px; left: 50%; transform: translateX(-50%); background: white; padding: 20px; border-radius: 10px; box-shadow: 0 4px 20px rgba(0,0,0,0.2); z-index: 1000;">
                <form method="get" action="/UserWorkspace/Search" class="search-form">
                    <input type="text" name="searchString" placeholder="Введите текст для поиска..." />
                    <button type="submit">Найти</button>
                    <button type="button" id="closeSearchBtn">Отмена</button>
                </form>
            </div>
            @RenderBody()
        </main>
    </div>

    <footer>
        <div class="footer-container">
            <ul>
                <li><p>Контакты:</p></li>
                <li>почта: <a href="mailto:senkxv@gmail.com">senkxv@gmail.com</a></li>
                <li>телефон: <a href="tel:+375256070373">+375 25 607-03-73</a></li>
                <li>github: <a href="https://github.com/senkxv">github/senkxv</a></li>
            </ul>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)

    <!-- Все скрипты в одном месте -->
    <script src="~/js/Index.js"></script>
    <script>
            function editSelectedDocument() {
                const id = sessionStorage.getItem('selectedDocumentId');
                if (id) {
                    window.location.href = '/UserWorkspace/EditDocumentPage?id=' + id;
                } else {
                    alert('Сначала выберите документ в таблице');
                }
            }

            function deleteSelectedDocument() {
                const id = sessionStorage.getItem('selectedDocumentId');
                if (id) {
                    if (confirm('Вы уверены, что хотите удалить документ?')) {
                        window.location.href = '/UserWorkspace/DeleteDocument?id=' + id;
                    }
                } else {
                    alert('Сначала выберите документ в таблице');
                }
            }

            // Поиск
            const searchModal = document.getElementById('searchModal');
            const searchLink = document.getElementById('searchLink');

            if (searchLink && searchModal) {
                searchLink.addEventListener('click', function(e) {
                    e.preventDefault();
                    searchModal.style.display = 'block';
                });
            }

            const closeSearchBtn = document.getElementById('closeSearchBtn');
            if (closeSearchBtn && searchModal) {
                closeSearchBtn.addEventListener('click', function() {
                    searchModal.style.display = 'none';
                });
            }

            // Закрыть модальное окно при клике вне его
            window.addEventListener('click', function(e) {
                if (searchModal && e.target === searchModal) {
                    searchModal.style.display = 'none';
                }
            });
    </script>
</body>
</html>