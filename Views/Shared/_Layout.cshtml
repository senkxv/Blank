<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover"/>

    <link rel="stylesheet" href="/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="/css/Modal/Filter.css" asp-append-version="true"/>
    <link rel="stylesheet" href="/css/Modal/Search.css" asp-append-version="true"/>
    <link rel="stylesheet" href="/css/Modal/Notification.css" asp-append-version="true"/>

    <script src="/js/Modal/Notification.js"></script>
    <script src="/js/UserWorkspace/Index.js"></script>
    <script src="/js/Modal/Filter.js"></script>
    <script src="/js/Modal/Search.js"></script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@300..700&family=SN+Pro:ital,wght@0,200..900;1,200..900&display=swap" rel="stylesheet"/>

    <link href="https://fonts.googleapis.com/css2?family=Rubik:ital,wght@0,300..900;1,300..900&family=SN+Pro:ital,wght@0,200..900;1,200..900&display=swap" rel="stylesheet"/>
</head>
<body>
    <header>
        <div class="header-container">
            <nav>
                <ul>
                    <li><a href="/UserWorkspace/Index">Главная</a></li>
                    <li><a href="/UserWorkspace/CreateDocumentPage">Добавить</a></li>
                    <li><a href="#" onclick="editSelectedDocument()">Изменить</a></li>
                    <li><a href="#" onclick="deleteSelectedDocument()">Удалить</a></li>
                    <li><a href="#" onclick="location.reload()">Обновить</a></li>
                    <li><a href="#" onclick="previewSelectedDocument()">Предпросмотр</a></li>
                    <li><a href="/UserWorkspace/ExportAllToExcel">Экспорт</a></li>
                    <li><a href="#">Импорт</a></li>
                    <li><a href="#" id="searchLink">Поиск</a></li>
                    <li><a href="#" id="filterLink">Фильтр</a></li>
                    <li><a href="/Login/Logout">Выход</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <div class="content-wrapper">
        <main>
            <div id="searchModal">
                <form method="get" action="/UserWorkspace/Search" class="search-form">
                    <input type="text" name="searchString" placeholder="Введите текст для поиска..." />
                    <button type="submit">Найти</button>
                    <button type="button" id="closeSearchBtn">Отмена</button>
                </form>
            </div>

            <div id="notificationModal">
                <div class="notification-content">
                    <p id="notificationMessage"></p>
                    <button id="closeNotificationBtn">Закрыть</button>
                </div>
            </div>

            <div id="filterModal">
                <div class="filter-content">
                    <h3>Настройка таблицы</h3>
        
                    <div class="filter-section">
                        <h4>Сортировка</h4>
                        <select id="sortField">
                            <option value="ид_документа">По порядковому номеру</option>
                            <option value="тип">По типу документа</option>
                            <option value="номер_документа">По номеру документа</option>
                            <option value="дата_создания">По дате создания</option>
                            <option value="грузоотправитель">По грузоотправителю</option>
                            <option value="перевозчик">По перевозчику</option>
                            <option value="грузополучатель">По грузополучателю</option>
                            <option value="ФИО_Водителя">По ФИО водителя</option>
                        </select>
                        <select id="sortOrder">
                            <option value="asc">По возрастанию</option>
                            <option value="desc">По убыванию</option>
                        </select>
                    </div>

                    <div class="filter-section">
                        <h4>Отображаемые столбцы</h4>
                        <div class="columns-grid">
                            <label><input type="checkbox" value="ид_документа" checked> Порядковый номер</label>
                            <label><input type="checkbox" value="тип" checked> Тип документа</label>
                            <label><input type="checkbox" value="номер_документа" checked> Номер документа</label>
                            <label><input type="checkbox" value="дата_создания" checked> Дата создания</label>
                            <label><input type="checkbox" value="грузоотправитель" checked> Грузоотправитель</label>
                            <label><input type="checkbox" value="перевозчик" checked> Перевозчик</label>
                            <label><input type="checkbox" value="грузополучатель" checked> Грузополучатель</label>
                            <label><input type="checkbox" value="пункт_погрузки" checked> Пункт погрузки</label>
                            <label><input type="checkbox" value="пункт_разгрузки" checked> Пункт разгрузки</label>
                            <label><input type="checkbox" value="ФИО_Водителя" checked> ФИО водителя</label>
                            <label><input type="checkbox" value="Марка_Машины" checked> Марка машины</label>
                            <label><input type="checkbox" value="Регистрационный_Номер" checked> Рег. номер</label>
                            <label><input type="checkbox" value="Тип_ТС" checked> Тип ТС</label>
                        </div>
                    </div>
                </div>

                <div class="filter-buttons">
                    <button id="applyFilterBtn">Применить</button>
                    <button id="closeFilterBtn">Отмена</button>
                </div>
            </div>

            @RenderBody()
        </main>
    </div>

    <footer>
        <div class="footer-container">
            <ul>
                <li><p>Контакты:</p></li>
                <li>почта: <a href="mailto:senkxv@gmail.com">senkxv@gmail.com</a></li>
                <li>телефон: <a href="tel:+375256070373">+375 25 607-03-73</a></li>
                <li>github: <a href="https://github.com/senkxv">github/senkxv</a></li>
            </ul>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>