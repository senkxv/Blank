@model Blank.Models.ViewModels.LoginViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Авторизация</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="/css/Login/Authorization.css"/>
    <script src="/js/Login/AuthorizationValidation.js" defer></script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@300..700&family=SN+Pro:ital,wght@0,200..900;1,200..900&display=swap" rel="stylesheet"/>

    <link href="https://fonts.googleapis.com/css2?family=SN+Pro:wght@400;700&display=swap" rel="stylesheet">
</head>
<body>
    <header>
        <p class="header-welcome-text">Авторизация пользователя</p>
    </header>
    
    <main>
        <section>
            <div class="form">
                <form method="post" asp-controller="Login" asp-action="Authorization" class="main-section-form">
                    @Html.AntiForgeryToken()

                    <p class="has-account">Хотите создать аккаунт? <a id="registration-link" href="/Login/Registration">Зарегистрироваться</a></p>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="error-message" style="margin-bottom: 15px;">
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <p style="margin: 5px 0;">@error.ErrorMessage</p>
                            }
                        </div>
                    }

                    <label for="Email">Электронная почта</label>
                    <input id="Email" type="email" name="Email" />

                    <label for="Password">Пароль</label>
                    <div class="password-wrapper">
                        <input id="Password" type="password" name="Password" />
                        <button type="button" class="toggle-password" data-target="Password">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M12 5C6 5 2.5 9.5 1 12C2.5 14.5 6 19 12 19C18 19 21.5 14.5 23 12C21.5 9.5 18 5 12 5Z"
                                      stroke="#666" stroke-width="1.5" fill="none" stroke-linecap="round" />
                                <circle cx="12" cy="12" r="2.5" stroke="#666" stroke-width="1.5" fill="none" />
                                <line x1="3" y1="3" x2="21" y2="21" stroke="#990000" stroke-width="1.5" stroke-linecap="round" />
                            </svg>
                        </button>
                    </div>
                    <input type="submit" value="Войти" />
                </form>
            </div>
        </section>
    </main>
    
    <footer></footer>
</body>
</html>